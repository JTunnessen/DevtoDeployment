# ============================================================
# devtodeploy — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Anthropic / Claude
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# GitHub
# ------------------------------------------------------------
GITHUB_TOKEN=ghp_...
# Organization name OR GitHub username
GITHUB_ORG=your-org-or-username

# ------------------------------------------------------------
# Jenkins (leave as placeholder if not yet provisioned)
# The pipeline will SKIP the Jenkins stage and log a warning
# if JENKINS_URL contains "your-jenkins" or is empty.
# See docs/jenkins_setup.md for full setup instructions.
# ------------------------------------------------------------
JENKINS_URL=http://your-jenkins:8080
JENKINS_USER=admin
JENKINS_API_TOKEN=
JENKINS_JOB_NAME=devtodeploy-functional

# ------------------------------------------------------------
# Cloud target (set based on --cloud flag you use at runtime)
# CLOUD_PROVIDER: azure | gcp
# DEPLOYMENT_TARGET:
#   Azure: app_service | aks
#   GCP:   cloud_run   | gke
# ------------------------------------------------------------
CLOUD_PROVIDER=azure
DEPLOYMENT_TARGET=app_service

# Azure credentials (required when CLOUD_PROVIDER=azure)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=devtodeploy-rg
AZURE_REGION=eastus

# GCP credentials (required when CLOUD_PROVIDER=gcp)
GCP_PROJECT_ID=
GCP_REGION=us-central1
# Path to a GCP service account JSON key file
GCP_CREDENTIALS_FILE=/path/to/service-account.json

# ------------------------------------------------------------
# Pipeline tuning (optional — defaults shown)
# ------------------------------------------------------------
MAX_DEV_ITERATIONS=10
MAX_LOAD_TEST_USERS=10000
LOAD_TEST_TOOL=k6
WORKSPACE_DIR=/tmp/devtodeploy
# Set to "true" to halt the pipeline if Jenkins returns FAILURE
HALT_ON_JENKINS_FAILURE=false
